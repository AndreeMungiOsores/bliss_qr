generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model QrLink {
  id          String   @id @default(cuid())
  slug        String   @unique
  type        String   @default("DYNAMIC")
  title       String
  targetUrl   String
  active      Boolean  @default(true)
  scanCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  style    QrStyle?
  visits   QrVisit[]
  versions QrDestinationVersion[]

  @@index([type], map: "bliss_qr_links_type_idx")
  @@index([active], map: "bliss_qr_links_active_idx")
  @@index([updatedAt], map: "bliss_qr_links_updated_at_idx")
  @@map("bliss_qr_links")
}

model QrStyle {
  id                   String @id @default(cuid())
  linkId               String @unique
  foregroundColor      String @default("#111827")
  backgroundColor      String @default("#ffffff")
  margin               Int    @default(2)
  size                 Int    @default(280)
  errorCorrectionLevel String @default("M")

  link QrLink @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@map("bliss_qr_styles")
}

model QrVisit {
  id        String   @id @default(cuid())
  linkId    String
  visitedAt DateTime @default(now())
  userAgent String?
  referer   String?
  ipHash    String?

  link QrLink @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId, visitedAt], map: "bliss_qr_visits_link_id_visited_at_idx")
  @@map("bliss_qr_visits")
}

model QrDestinationVersion {
  id        String   @id @default(cuid())
  linkId    String
  oldUrl    String
  newUrl    String
  changedAt DateTime @default(now())

  link QrLink @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId, changedAt], map: "bliss_qr_destination_versions_link_id_changed_at_idx")
  @@map("bliss_qr_destination_versions")
}
